# BioYoda Environment Configuration
# Simple .env file for both bash and Python scripts

# Project Settings
PROJECT_NAME="bioyoda"
PROJECT_VERSION="1.0.0"
ENVIRONMENT="production"  # development, testing, production

# Paths (relative to project root)
PROJECT_ROOT="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda"
DATA_DIR="data"
LOGS_DIR="logs"
SCRIPTS_DIR="scripts"

# Data Directories
RAW_PUBMED_DIR="data/raw/pubmed"
PROCESSED_PUBMED_DIR="data/processed/pubmed"
FINAL_PUBMED_DIR="data/final/pubmed"

# PubMed Processing Settings
PUBMED_BATCH_SIZE=10
PUBMED_MAX_JOBS=50
PUBMED_MEMORY_PER_JOB="8G"
PUBMED_MERGE_MEMORY="64G"
PUBMED_MERGE_METHOD="merge3"

# Vector Settings
VECTOR_MODEL="all-MiniLM-L6-v2"
VECTOR_DIMENSION=384
INDEX_TYPE="IndexFlatL2"

# Conda Environment
CONDA_ENV="bioyoda"

# HPC Cluster Settings
CLUSTER_SCHEDULER="sge"
CLUSTER_QUEUE="scc"
DEFAULT_MEMORY="8G"
DEFAULT_RUNTIME="02:00:00"
LARGE_MEMORY="64G"
LARGE_RUNTIME="12:00:00"

# API Settings
API_HOST="0.0.0.0"
API_PORT=8000
API_WORKERS=1

# Debug Settings (for development)
DEBUG_MODE="false"
DEBUG_SAMPLE_SIZE=10

# Logging
LOG_LEVEL="INFO"