# PubMed Processing Configuration

# Data Directories
BASE_DATA_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/raw/pubmed"
PROCESSED_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/processed/pubmed"
FINAL_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/final/pubmed"
LOG_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/logs/pubmed"

# script Directories
SCRIPTS_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/scripts/pubmed"

# Processing Settings
FILE_LIST="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/final/pubmed/pubmed_files.txt"
CONDA_ENV="bioyoda"

# Job Resources
PROCESS_MEMORY="12G"
PROCESS_RUNTIME="168:00:00"
MERGE_MEMORY="256G"
MERGE_RUNTIME="168:00:00"
CLUSTER_QUEUE="scc"

# Merge Settings
MERGE_METHOD="merge3"

# Model Settings
#MODEL_NAME="all-MiniLM-L6-v2"
#VECTOR_DIMENSION=384
MODEL_NAME=pritamdeka/S-BioBERT-snli-multinli-stsb
VECTOR_DIMENSION=768

# Debug Settings
DEBUG_SAMPLE_SIZE=10