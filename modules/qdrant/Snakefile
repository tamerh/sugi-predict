import os
import sys
from datetime import datetime

# Generate timestamp for this run (all logs will use same timestamp)
RUN_TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")

# Load configuration
configfile: "config/config.yaml"

# Construct paths
# BASE_DIR: where outputs go (from main Snakefile)
# PROJECT_ROOT: where code lives (from main Snakefile or calculated)
BASE_DIR = config["base_dir"]
PROJECT_ROOT = config.get("project_root", os.path.dirname(os.path.dirname(os.path.dirname(workflow.snakefile))))

# Check update mode
UPDATE_MODE = config.get("update_mode", "full")

# Module-specific paths
QDRANT_MODULE_DIR = os.path.join(PROJECT_ROOT, "modules", "qdrant")  # Scripts in project root
QDRANT_SCRIPTS = os.path.join(QDRANT_MODULE_DIR, "scripts")

# Storage and log paths
QDRANT_STORAGE = os.path.join(BASE_DIR, "data", "qdrant")
QDRANT_LOG_DIR = os.path.join(BASE_DIR, "logs", "qdrant")
CONNECTION_INFO = os.path.join(QDRANT_STORAGE, "connection_info.txt")

# Update config with constructed paths
config["logs_dir"] = os.path.join(BASE_DIR, "logs")  # Required for LOG_cluster_log
config["qdrant"]["storage_dir"] = QDRANT_STORAGE
config["qdrant"]["log_dir"] = QDRANT_LOG_DIR

# Collection directories (where processed data lives)
PUBMED_FAISS_DIR = os.path.join(BASE_DIR, "data", "processed", "pubmed")
CLINICAL_TRIALS_FAISS_DIR = os.path.join(BASE_DIR, "data", "processed", "clinical_trials")
PATENTS_TEXT_FAISS_DIR = os.path.join(BASE_DIR, "data", "processed", "patents", "text")
PATENTS_COMPOUNDS_FAISS_DIR = os.path.join(BASE_DIR, "data", "processed", "patents", "compounds")

# Tracking files
STATE_DIR = os.path.join(BASE_DIR, "state")
PUBMED_TRACKING_FILE = os.path.join(STATE_DIR, "pubmed", "processed_files.json")
CLINICAL_TRIALS_TRACKING_FILE = os.path.join(STATE_DIR, "clinical_trials", "processed_files.json")
PATENTS_TEXT_TRACKING_FILE = os.path.join(STATE_DIR, "patents", "processed_chunks.json")
PATENTS_COMPOUNDS_TRACKING_FILE = os.path.join(STATE_DIR, "patents", "processed_compounds_chunks.json")

# Ensure directories exist
os.makedirs(QDRANT_STORAGE, exist_ok=True)
os.makedirs(f"{QDRANT_STORAGE}/collections", exist_ok=True)
os.makedirs(QDRANT_LOG_DIR, exist_ok=True)
os.makedirs(os.path.join(STATE_DIR, "pubmed"), exist_ok=True)
os.makedirs(os.path.join(STATE_DIR, "clinical_trials"), exist_ok=True)
os.makedirs(os.path.join(STATE_DIR, "patents"), exist_ok=True)

# Local rules
localrules: insert_all

# ============================================================================
# Top-level targets
# ============================================================================

rule insert_all:
    """Insert all datasets to Qdrant."""
    input:
        f"{QDRANT_STORAGE}/collections/pubmed_abstracts.done",
        f"{QDRANT_STORAGE}/collections/clinical_trials.done",
        f"{QDRANT_STORAGE}/collections/patents_text.done",
        f"{QDRANT_STORAGE}/collections/patents_compounds.done"
    default_target: True

rule insert_pubmed:
    """Insert only PubMed to Qdrant."""
    input:
        f"{QDRANT_STORAGE}/collections/pubmed_abstracts.done"

rule insert_clinical_trials:
    """Insert only Clinical Trials to Qdrant."""
    input:
        f"{QDRANT_STORAGE}/collections/clinical_trials.done"

rule insert_patents_text:
    """Insert only Patents Text to Qdrant."""
    input:
        f"{QDRANT_STORAGE}/collections/patents_text.done"

rule insert_patents_compounds:
    """Insert only Patents Compounds to Qdrant."""
    input:
        f"{QDRANT_STORAGE}/collections/patents_compounds.done"

rule insert_patents:
    """Insert both Patents collections to Qdrant."""
    input:
        f"{QDRANT_STORAGE}/collections/patents_text.done",
        f"{QDRANT_STORAGE}/collections/patents_compounds.done"

# ============================================================================
# Rule: Insert PubMed to Qdrant
# ============================================================================

rule insert_pubmed_to_qdrant:
    """
    Insert PubMed FAISS files to Qdrant collection.
    Assumes Qdrant server is already running and connection_info.txt exists.
    Assumes PubMed data processing is complete.

    Note: Tracking file is an input dependency so rule re-runs when new files
    are processed (e.g., in update mode).
    """
    input:
        connection_info = CONNECTION_INFO,
        tracking_file = PUBMED_TRACKING_FILE if os.path.exists(PUBMED_TRACKING_FILE) else []
    output:
        done = f"{QDRANT_STORAGE}/collections/pubmed_abstracts.done"
    params:
        collection = config["pubmed"]["qdrant"]["collection_name"],
        batch_size = config["pubmed"]["qdrant"]["batch_size"],
        hnsw_m = config["pubmed"]["qdrant"]["hnsw_m"],
        hnsw_ef_construct = config["pubmed"]["qdrant"]["hnsw_ef_construct"],
        indexing_threshold = config["pubmed"]["qdrant"]["indexing_threshold"],
        max_segment_size = config["pubmed"]["qdrant"]["max_segment_size"],
        default_segment_number = config["pubmed"]["qdrant"]["default_segment_number"],
        prefer_grpc = config["pubmed"]["qdrant"].get("prefer_grpc", False),
        faiss_dir = PUBMED_FAISS_DIR,
        tracking_file = PUBMED_TRACKING_FILE,
        script = f"{QDRANT_SCRIPTS}/insert_from_faiss.py",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "insert_pubmed_to_qdrant_cluster.log")
    resources:
        mem_mb = config["pubmed"]["qdrant"]["memory_mb"]
    conda:
        config["conda_env"]
    log:
        f"{QDRANT_LOG_DIR}/insert_pubmed_{RUN_TIMESTAMP}.log"
    shell:
        """
echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Check if connection info exists
        if [ ! -f {input.connection_info} ]; then
            echo "ERROR: Connection info not found at {input.connection_info}" | tee -a {log}
            echo "Please start Qdrant server first: ./bioyoda.sh qdrant start" | tee -a {log}
            exit 1
        fi

        # Source connection info
        source {input.connection_info}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Inserting PubMed to Qdrant..." >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Qdrant URL: $QDRANT_URL" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Collection: {params.collection}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS dir: {params.faiss_dir}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Tracking file: {params.tracking_file}" >> {log}

        # Check if FAISS data exists (search recursively in subdirectories)
        if [ ! -d {params.faiss_dir} ] || [ -z "$(find {params.faiss_dir} -name '*.index' -type f 2>/dev/null | head -1)" ]; then
            echo "ERROR: No FAISS data found in {params.faiss_dir}" | tee -a {log}
            echo "Please run PubMed processing first: ./bioyoda.sh run pubmed" | tee -a {log}
            exit 1
        fi

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting insertion (detailed logs: {log})"

        # Build insertion command with tracking file if it exists
        TRACKING_FLAG=""
        if [ -f {params.tracking_file} ]; then
            TRACKING_FLAG="--tracking-file {params.tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using tracking file for incremental updates" >> {log}
        fi

        # Build gRPC flag if enabled
        GRPC_FLAG=""
        if [ "{params.prefer_grpc}" = "True" ]; then
            GRPC_FLAG="--prefer-grpc"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] gRPC protocol enabled (20-30% faster bulk inserts)" >> {log}
        fi

        python {params.script} \
            --faiss-dir {params.faiss_dir} \
            --collection {params.collection} \
            --qdrant-url $QDRANT_URL \
            --batch-size {params.batch_size} \
            --hnsw-m {params.hnsw_m} \
            --hnsw-ef-construct {params.hnsw_ef_construct} \
            --indexing-threshold {params.indexing_threshold} \
            --max-segment-size {params.max_segment_size} \
            --default-segment-number {params.default_segment_number} \
            $TRACKING_FLAG \
            $GRPC_FLAG \
            >> {log} 2>&1

        # Mark as done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] PubMed insertion complete" > {output.done}
        echo "Completed at: $(date)" >> {output.done}
        """

# ============================================================================
# Rule: Insert Clinical Trials to Qdrant
# ============================================================================

rule insert_clinical_trials_to_qdrant:
    """
    Insert Clinical Trials to Qdrant collection.
    Assumes Qdrant server is already running and connection_info.txt exists.
    Assumes Clinical Trials data processing is complete.

    Note: Tracking file is an input dependency so rule re-runs when new files
    are processed (e.g., in update mode).
    """
    input:
        connection_info = CONNECTION_INFO,
        tracking_file = CLINICAL_TRIALS_TRACKING_FILE if os.path.exists(CLINICAL_TRIALS_TRACKING_FILE) else []
    output:
        done = f"{QDRANT_STORAGE}/collections/clinical_trials.done"
    params:
        collection = config["clinical_trials"]["qdrant"]["collection_name"],
        batch_size = config["clinical_trials"]["qdrant"]["batch_size"],
        hnsw_m = config["clinical_trials"]["qdrant"]["hnsw_m"],
        hnsw_ef_construct = config["clinical_trials"]["qdrant"]["hnsw_ef_construct"],
        indexing_threshold = config["clinical_trials"]["qdrant"]["indexing_threshold"],
        max_segment_size = config["clinical_trials"]["qdrant"]["max_segment_size"],
        default_segment_number = config["clinical_trials"]["qdrant"]["default_segment_number"],
        prefer_grpc = config["clinical_trials"]["qdrant"].get("prefer_grpc", False),
        faiss_dir = CLINICAL_TRIALS_FAISS_DIR,
        tracking_file = CLINICAL_TRIALS_TRACKING_FILE,
        chunk_tracking_file = config["clinical_trials"].get("update", {}).get("chunk_tracking_file", os.path.join(STATE_DIR, "clinical_trials", "processed_chunks.json")),
        script = f"{QDRANT_SCRIPTS}/insert_from_faiss.py",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "insert_clinical_trials_to_qdrant_cluster.log")
    resources:
        mem_mb = config["clinical_trials"]["qdrant"]["memory_mb"]
    conda:
        config["conda_env"]
    log:
        f"{QDRANT_LOG_DIR}/insert_clinical_trials_{RUN_TIMESTAMP}.log"
    shell:
        """
echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Check if connection info exists
        if [ ! -f {input.connection_info} ]; then
            echo "ERROR: Connection info not found at {input.connection_info}" | tee -a {log}
            echo "Please start Qdrant server first: ./bioyoda.sh qdrant start" | tee -a {log}
            exit 1
        fi

        # Source connection info
        source {input.connection_info}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Inserting Clinical Trials to Qdrant..." >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Qdrant URL: $QDRANT_URL" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Collection: {params.collection}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS dir: {params.faiss_dir}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Tracking file: {params.tracking_file}" >> {log}

        # Check if FAISS data exists (search recursively in subdirectories)
        if [ ! -d {params.faiss_dir} ] || [ -z "$(find {params.faiss_dir} -name '*.index' -type f 2>/dev/null | head -1)" ]; then
            echo "ERROR: No FAISS data found in {params.faiss_dir}" | tee -a {log}
            echo "Please run Clinical Trials processing first: ./bioyoda.sh run clinical_trials" | tee -a {log}
            exit 1
        fi

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting insertion (detailed logs: {log})"

        # Build insertion command with tracking file if it exists
        TRACKING_FLAG=""
        if [ -f {params.tracking_file} ]; then
            TRACKING_FLAG="--tracking-file {params.tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using tracking file for incremental updates" >> {log}
        fi

        # Build chunk tracking flag if enabled
        CHUNK_TRACKING_FLAG=""
        if [ -n "{params.chunk_tracking_file}" ]; then
            CHUNK_TRACKING_FLAG="--chunk-tracking-file {params.chunk_tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using chunk tracking file: {params.chunk_tracking_file}" >> {log}
        fi

        # Add update mode flag for clinical trials (enables deletion before insertion)
        UPDATE_MODE_FLAG=""
        if [[ "{UPDATE_MODE}" == "update" ]]; then
            UPDATE_MODE_FLAG="--update-mode"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Update mode enabled: will delete old vectors before inserting" >> {log}
        fi

        # Build gRPC flag if enabled
        GRPC_FLAG=""
        if [ "{params.prefer_grpc}" = "True" ]; then
            GRPC_FLAG="--prefer-grpc"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] gRPC protocol enabled (20-30% faster bulk inserts)" >> {log}
        fi

        python {params.script} \
            --faiss-dir {params.faiss_dir} \
            --collection {params.collection} \
            --qdrant-url $QDRANT_URL \
            --batch-size {params.batch_size} \
            --hnsw-m {params.hnsw_m} \
            --hnsw-ef-construct {params.hnsw_ef_construct} \
            --indexing-threshold {params.indexing_threshold} \
            --max-segment-size {params.max_segment_size} \
            --default-segment-number {params.default_segment_number} \
            $TRACKING_FLAG \
            $CHUNK_TRACKING_FLAG \
            $UPDATE_MODE_FLAG \
            $GRPC_FLAG \
            >> {log} 2>&1

        # Mark as done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Clinical Trials insertion complete" > {output.done}
        echo "Completed at: $(date)" >> {output.done}
        """

# ============================================================================
# Rule: Insert Patents Text to Qdrant
# ============================================================================

rule insert_patents_text_to_qdrant:
    """
    Insert Patents Text FAISS files to Qdrant collection.
    Creates a separate collection for patent text embeddings (S-BioBERT, 768-dim).
    """
    input:
        connection_info = CONNECTION_INFO,
        tracking_file = PATENTS_TEXT_TRACKING_FILE if os.path.exists(PATENTS_TEXT_TRACKING_FILE) else []
    output:
        done = f"{QDRANT_STORAGE}/collections/patents_text.done"
    params:
        collection = config["patents"]["qdrant"]["text_collection_name"],
        batch_size = config["patents"]["qdrant"]["batch_size"],
        hnsw_m = config["patents"]["qdrant"]["text_hnsw_m"],
        hnsw_ef_construct = config["patents"]["qdrant"]["text_hnsw_ef_construct"],
        indexing_threshold = config["patents"]["qdrant"]["text_indexing_threshold"],
        max_segment_size = config["patents"]["qdrant"]["text_max_segment_size"],
        default_segment_number = config["patents"]["qdrant"]["text_default_segment_number"],
        prefer_grpc = config["patents"]["qdrant"].get("prefer_grpc", False),
        faiss_dir = PATENTS_TEXT_FAISS_DIR,
        tracking_file = PATENTS_TEXT_TRACKING_FILE,
        chunk_tracking_file = PATENTS_TEXT_TRACKING_FILE,
        script = f"{QDRANT_SCRIPTS}/insert_from_faiss.py",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "insert_patents_text_to_qdrant_cluster.log")
    resources:
        mem_mb = config["patents"]["qdrant"]["memory_mb"]
    conda:
        config["conda_env"]
    log:
        f"{QDRANT_LOG_DIR}/insert_patents_text_{RUN_TIMESTAMP}.log"
    shell:
        """
        echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Check if connection info exists
        if [ ! -f {input.connection_info} ]; then
            echo "ERROR: Connection info not found at {input.connection_info}" | tee -a {log}
            echo "Please start Qdrant server first: ./bioyoda.sh qdrant start" | tee -a {log}
            exit 1
        fi

        # Source connection info
        source {input.connection_info}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Inserting Patents Text to Qdrant..." >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Qdrant URL: $QDRANT_URL" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Collection: {params.collection}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS dir: {params.faiss_dir}" >> {log}

        # Check if FAISS data exists
        if [ ! -d {params.faiss_dir} ] || [ -z "$(find {params.faiss_dir} -name '*.index' -type f 2>/dev/null | head -1)" ]; then
            echo "ERROR: No FAISS data found in {params.faiss_dir}" | tee -a {log}
            echo "Please run Patents processing first: ./bioyoda.sh run patents" | tee -a {log}
            exit 1
        fi

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting insertion (detailed logs: {log})"

        # Build tracking flag if exists
        TRACKING_FLAG=""
        if [ -f {params.tracking_file} ]; then
            TRACKING_FLAG="--tracking-file {params.tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using tracking file for incremental updates" >> {log}
        fi

        # Build chunk tracking flag (same file for patents - unified tracking)
        CHUNK_TRACKING_FLAG=""
        if [ -n "{params.chunk_tracking_file}" ] && [ -f {params.chunk_tracking_file} ]; then
            CHUNK_TRACKING_FLAG="--chunk-tracking-file {params.chunk_tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using chunk tracking file: {params.chunk_tracking_file}" >> {log}
        fi

        # Build gRPC flag if enabled
        GRPC_FLAG=""
        if [ "{params.prefer_grpc}" = "True" ]; then
            GRPC_FLAG="--prefer-grpc"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] gRPC protocol enabled" >> {log}
        fi

        python {params.script} \
            --faiss-dir {params.faiss_dir} \
            --collection {params.collection} \
            --qdrant-url $QDRANT_URL \
            --batch-size {params.batch_size} \
            --hnsw-m {params.hnsw_m} \
            --hnsw-ef-construct {params.hnsw_ef_construct} \
            --indexing-threshold {params.indexing_threshold} \
            --max-segment-size {params.max_segment_size} \
            --default-segment-number {params.default_segment_number} \
            $TRACKING_FLAG \
            $CHUNK_TRACKING_FLAG \
            $GRPC_FLAG \
            >> {log} 2>&1

        # Mark as done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Patents Text insertion complete" > {output.done}
        echo "Completed at: $(date)" >> {output.done}
        """

# ============================================================================
# Rule: Insert Patents Compounds to Qdrant
# ============================================================================

rule insert_patents_compounds_to_qdrant:
    """
    Insert Patents Compounds FAISS files to Qdrant collection.
    Creates a separate collection for chemical fingerprints (Morgan, 2048-bit).
    """
    input:
        connection_info = CONNECTION_INFO,
        tracking_file = PATENTS_COMPOUNDS_TRACKING_FILE if os.path.exists(PATENTS_COMPOUNDS_TRACKING_FILE) else []
    output:
        done = f"{QDRANT_STORAGE}/collections/patents_compounds.done"
    params:
        collection = config["patents"]["qdrant"]["compounds_collection_name"],
        batch_size = config["patents"]["qdrant"]["batch_size"],
        hnsw_m = config["patents"]["qdrant"]["compounds_hnsw_m"],
        hnsw_ef_construct = config["patents"]["qdrant"]["compounds_hnsw_ef_construct"],
        indexing_threshold = config["patents"]["qdrant"]["compounds_indexing_threshold"],
        max_segment_size = config["patents"]["qdrant"]["compounds_max_segment_size"],
        default_segment_number = config["patents"]["qdrant"]["compounds_default_segment_number"],
        prefer_grpc = config["patents"]["qdrant"].get("prefer_grpc", False),
        faiss_dir = PATENTS_COMPOUNDS_FAISS_DIR,
        tracking_file = PATENTS_COMPOUNDS_TRACKING_FILE,
        chunk_tracking_file = PATENTS_COMPOUNDS_TRACKING_FILE,
        script = f"{QDRANT_SCRIPTS}/insert_from_faiss.py",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "insert_patents_compounds_to_qdrant_cluster.log")
    resources:
        mem_mb = config["patents"]["qdrant"]["memory_mb"]
    conda:
        config["conda_env"]
    log:
        f"{QDRANT_LOG_DIR}/insert_patents_compounds_{RUN_TIMESTAMP}.log"
    shell:
        """
        echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Check if connection info exists
        if [ ! -f {input.connection_info} ]; then
            echo "ERROR: Connection info not found at {input.connection_info}" | tee -a {log}
            echo "Please start Qdrant server first: ./bioyoda.sh qdrant start" | tee -a {log}
            exit 1
        fi

        # Source connection info
        source {input.connection_info}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Inserting Patents Compounds to Qdrant..." >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Qdrant URL: $QDRANT_URL" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Collection: {params.collection}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS dir: {params.faiss_dir}" >> {log}

        # Check if FAISS data exists
        if [ ! -d {params.faiss_dir} ] || [ -z "$(find {params.faiss_dir} -name '*.index' -type f 2>/dev/null | head -1)" ]; then
            echo "ERROR: No FAISS data found in {params.faiss_dir}" | tee -a {log}
            echo "Please run Patents processing first: ./bioyoda.sh run patents" | tee -a {log}
            exit 1
        fi

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting insertion (detailed logs: {log})"

        # Build tracking flag if exists
        TRACKING_FLAG=""
        if [ -f {params.tracking_file} ]; then
            TRACKING_FLAG="--tracking-file {params.tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using tracking file for incremental updates" >> {log}
        fi

        # Build chunk tracking flag (same file for patents - unified tracking)
        CHUNK_TRACKING_FLAG=""
        if [ -n "{params.chunk_tracking_file}" ] && [ -f {params.chunk_tracking_file} ]; then
            CHUNK_TRACKING_FLAG="--chunk-tracking-file {params.chunk_tracking_file}"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Using chunk tracking file: {params.chunk_tracking_file}" >> {log}
        fi

        # Build gRPC flag if enabled
        GRPC_FLAG=""
        if [ "{params.prefer_grpc}" = "True" ]; then
            GRPC_FLAG="--prefer-grpc"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] gRPC protocol enabled" >> {log}
        fi

        python {params.script} \
            --faiss-dir {params.faiss_dir} \
            --collection {params.collection} \
            --qdrant-url $QDRANT_URL \
            --batch-size {params.batch_size} \
            --vector-size 2048 \
            --hnsw-m {params.hnsw_m} \
            --hnsw-ef-construct {params.hnsw_ef_construct} \
            --indexing-threshold {params.indexing_threshold} \
            --max-segment-size {params.max_segment_size} \
            --default-segment-number {params.default_segment_number} \
            $TRACKING_FLAG \
            $CHUNK_TRACKING_FLAG \
            $GRPC_FLAG \
            >> {log} 2>&1

        # Mark as done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Patents Compounds insertion complete" > {output.done}
        echo "Completed at: $(date)" >> {output.done}
        """

# ============================================================================
# Pipeline Completion Handlers
# ============================================================================

onsuccess:
    print("\n" + "="*80, file=sys.stderr)
    print("Qdrant insertion completed successfully!", file=sys.stderr)
    print("="*80, file=sys.stderr)

onerror:
    print("\n" + "="*80, file=sys.stderr)
    print("Qdrant insertion failed!", file=sys.stderr)
    print("="*80, file=sys.stderr)
