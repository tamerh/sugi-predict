import os
import time
import subprocess

# Module-specific configuration
QDRANT_MODULE_DIR = "modules/qdrant"
QDRANT_SCRIPTS = f"{QDRANT_MODULE_DIR}/scripts"
QDRANT_SETUP = f"{QDRANT_MODULE_DIR}/setup"

# Paths from config
QDRANT_STORAGE = config["qdrant"]["storage_dir"]
QDRANT_LOG_DIR = config["qdrant"]["log_dir"]
QDRANT_CONTAINER = f"{QDRANT_SETUP}/singularity/qdrant.sif"
QDRANT_CONFIG = f"{QDRANT_SETUP}/singularity/config.yaml"
CONNECTION_INFO = f"{QDRANT_STORAGE}/connection_info.txt"

# Collection directories
PUBMED_FAISS_DIR = config["pubmed"]["processed_dir"]
CLINICAL_TRIALS_FAISS_DIR = config["clinical_trials"]["final_dir"]
CLINICAL_TRIALS_DATA = config["clinical_trials"]["final_index"]

# Ensure directories exist
os.makedirs(QDRANT_STORAGE, exist_ok=True)
os.makedirs(f"{QDRANT_STORAGE}/collections", exist_ok=True)
os.makedirs(QDRANT_LOG_DIR, exist_ok=True)

# Local rules - these run on head node, not submitted to cluster
localrules: start_qdrant_server, qdrant_all

# ============================================================================
# Rule: Start Qdrant Server
# ============================================================================

# workflow.cores > 1  # Heuristic: cluster mode if cores > 1
rule start_qdrant_server:
    """
    Start Qdrant server (local mode or cluster job).
    Creates connection_info.txt with server hostname and port.
    Server starts on-demand when insert rules need it.
    Insert rules already have proper data dependencies.
    """
    output:
        connection_info = CONNECTION_INFO
    params:
        script = f"{QDRANT_SCRIPTS}/start_server.sh",
        container = QDRANT_CONTAINER,
        config_file = QDRANT_CONFIG,
        storage = QDRANT_STORAGE,
        memory_mb = config["qdrant"]["server"]["memory_mb"],
        runtime = config["qdrant"]["server"]["runtime_hours"] * 3600,
        job_name = "qdrant_server",
        is_cluster = config.get("execution_mode", "local") == "cluster",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "start_qdrant_server_cluster.log")
    log:
        f"{QDRANT_LOG_DIR}/server.log"
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Detect execution mode
        if [ "{params.is_cluster}" = "True" ]; then
            MODE="cluster"
        else
            MODE="local"
        fi

        # Run the start server script
        bash {params.script} \
            --container {params.container} \
            --config {params.config_file} \
            --storage {params.storage} \
            --memory-mb {params.memory_mb} \
            --runtime {params.runtime} \
            --job-name {params.job_name} \
            --mode $MODE \
            --connection-info {output.connection_info} \
            --log {log} \
            2>&1 | tee -a {log}
        """

# ============================================================================
# Rule: Insert PubMed to Qdrant
# ============================================================================

rule insert_pubmed_to_qdrant:
    """
    Insert PubMed FAISS files to Qdrant collection.
    Processes all individual FAISS files sequentially.
    Waits for PubMed processing to complete before insertion.
    """
    input:
        pubmed_complete = rules.pubmed_processing_complete.output.done,  # Wait for FAISS processing
        connection_info = rules.start_qdrant_server.output.connection_info
    output:
        done = f"{QDRANT_STORAGE}/collections/pubmed_abstracts.done"
    params:
        collection = config["pubmed"]["qdrant"]["collection_name"],
        batch_size = config["qdrant"]["batch_size"],
        faiss_dir = PUBMED_FAISS_DIR,
        script = f"{QDRANT_SCRIPTS}/insert_from_faiss.py",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "insert_pubmed_to_qdrant_cluster.log")
    resources:
        mem_mb = config["pubmed"]["qdrant"]["memory_mb"]
    conda:
        config["conda_env"]
    log:
        f"{QDRANT_LOG_DIR}/insert_pubmed.log"
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Source connection info
        source {input.connection_info}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Inserting PubMed to Qdrant..." >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Qdrant URL: $QDRANT_URL" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Collection: {params.collection}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS dir: {params.faiss_dir}" >> {log}

        python {params.script} \
            --faiss-dir {params.faiss_dir} \
            --collection {params.collection} \
            --qdrant-url $QDRANT_URL \
            --batch-size {params.batch_size} \
            2>&1 | tee -a {log}

        # Mark as done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] PubMed insertion complete" > {output.done}
        echo "Completed at: $(date)" >> {output.done}
        """

# ============================================================================
# Rule: Insert Clinical Trials to Qdrant
# ============================================================================

rule insert_clinical_trials_to_qdrant:
    """
    Insert Clinical Trials to Qdrant collection.
    Independent of PubMed - can run separately.
    """
    input:
        trials_data = CLINICAL_TRIALS_DATA,
        connection_info = rules.start_qdrant_server.output.connection_info
    output:
        done = f"{QDRANT_STORAGE}/collections/clinical_trials.done"
    params:
        collection = config["clinical_trials"]["qdrant"]["collection_name"],
        batch_size = config["qdrant"]["batch_size"],
        faiss_dir = CLINICAL_TRIALS_FAISS_DIR,
        script = f"{QDRANT_SCRIPTS}/insert_from_faiss.py",  # Will create separate script if needed
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "insert_clinical_trials_to_qdrant_cluster.log")
    resources:
        mem_mb = config["clinical_trials"]["qdrant"]["memory_mb"]
    conda:
        config["conda_env"]
    log:
        f"{QDRANT_LOG_DIR}/insert_clinical_trials.log"
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}

        # Source connection info
        source {input.connection_info}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Inserting Clinical Trials to Qdrant..." >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Qdrant URL: $QDRANT_URL" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Collection: {params.collection}" >> {log}
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS dir: {params.faiss_dir}" >> {log}

        python {params.script} \
            --faiss-dir {params.faiss_dir} \
            --collection {params.collection} \
            --qdrant-url $QDRANT_URL \
            --batch-size {params.batch_size} \
            2>&1 | tee -a {log}

        # Mark as done
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Clinical Trials insertion (TODO)" > {output.done}
        echo "Completed at: $(date)" >> {output.done}
        """

# ============================================================================
# Rule: Export Qdrant to FAISS (Optional Backup)
# ============================================================================

rule export_qdrant_to_faiss:
    """
    Export Qdrant collection back to FAISS format (lossless backup).
    Optional step for archival purposes.
    """
    input:
        done = rules.insert_pubmed_to_qdrant.output.done,
        connection_info = rules.start_qdrant_server.output.connection_info
    output:
        index = f"{config['final_dir']}/pubmed/from_qdrant.index",
        metadata = f"{config['final_dir']}/pubmed/from_qdrant_metadata.pkl"
    params:
        collection = config["pubmed"]["qdrant"]["collection_name"],
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "export_qdrant_to_faiss.log")
    resources:
        mem_mb = 100000  # ~100GB for full export
    log:
        f"{QDRANT_LOG_DIR}/export_to_faiss.log"
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}

        echo "[$(date '+%Y-%m-%d %H:%M:%S')] FAISS export not yet implemented" >> {log}
        echo "This will export Qdrant → FAISS for backup" >> {log}

        # TODO: Implement export script
        touch {output.index}
        touch {output.metadata}
        """

# ============================================================================
# Top-level target for Qdrant module
# ============================================================================

rule qdrant_all:
    input:
        rules.insert_pubmed_to_qdrant.output.done,
        rules.insert_clinical_trials_to_qdrant.output.done
    default_target: True
