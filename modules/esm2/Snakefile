##############################################################################
#
#   Protein Similarity ESM-2 Module - Snakemake Workflow
#
#   Processes UniProt protein sequences to generate ESM-2 embeddings
#   Pipeline: download → split → generate_embeddings → merge
#
##############################################################################

import os
from pathlib import Path
from datetime import datetime

# Generate timestamp for this run (all logs will use same timestamp)
RUN_TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")

# Load module-specific configuration
esm2_config = config["esm2"]

# Construct paths
BASE_DIR = config["base_dir"]
PROJECT_ROOT = config.get("project_root", os.path.dirname(os.path.dirname(os.path.dirname(workflow.snakefile))))

# Dataset selection - use "test" in test mode
TEST_MODE = esm2_config.get("test_mode", False)
if TEST_MODE:
    DATASET = "test"
else:
    DATASET = esm2_config.get("dataset", "swissprot")

# Paths
RAW_DIR = os.path.join(BASE_DIR, "raw_data", "esm2")
PROCESSED_DIR = os.path.join(BASE_DIR, "data", "processed", "esm2")
CHUNKS_DIR = os.path.join(RAW_DIR, "chunks")
EMBEDDINGS_DIR = os.path.join(PROCESSED_DIR, "embeddings")
MERGED_DIR = os.path.join(PROCESSED_DIR, "merged")
QDRANT_DIR = os.path.join(PROCESSED_DIR, "qdrant")
LOG_DIR = os.path.join(BASE_DIR, "logs", "esm2")
esm2_module_scripts = os.path.join(PROJECT_ROOT, "modules", "esm2", "scripts")
ESM2_STATE_DIR = os.path.join(BASE_DIR, "state", "esm2")

# Update config with constructed paths for downstream use
esm2_config["raw_dir"] = RAW_DIR
esm2_config["processed_dir"] = PROCESSED_DIR
esm2_config["chunks_dir"] = CHUNKS_DIR
esm2_config["embeddings_dir"] = EMBEDDINGS_DIR
esm2_config["merged_dir"] = MERGED_DIR
esm2_config["qdrant_dir"] = QDRANT_DIR
esm2_config["log_dir"] = LOG_DIR

# Create directories
os.makedirs(RAW_DIR, exist_ok=True)
os.makedirs(PROCESSED_DIR, exist_ok=True)
os.makedirs(CHUNKS_DIR, exist_ok=True)
os.makedirs(EMBEDDINGS_DIR, exist_ok=True)
os.makedirs(MERGED_DIR, exist_ok=True)
os.makedirs(QDRANT_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)
os.makedirs(ESM2_STATE_DIR, exist_ok=True)

# ESM-2 model parameters
ESM_MODEL = esm2_config["model_name"]
BATCH_SIZE = esm2_config["batch_size"]
DEVICE = esm2_config["device"]
REPR_LAYER = esm2_config["repr_layer"]
MAX_SEQ_LEN = esm2_config["max_seq_len"]

# Use test_num_chunks in test mode, otherwise use regular num_chunks
if TEST_MODE:
    NUM_CHUNKS = esm2_config.get("test_num_chunks", 10)
else:
    NUM_CHUNKS = esm2_config["num_chunks"]

# File paths
if DATASET == "test":
    RAW_FASTA = os.path.join(RAW_DIR, "uniprot_test.fasta")
else:
    RAW_FASTA = os.path.join(RAW_DIR, f"uniprot_{DATASET}.fasta")

MERGED_EMBEDDINGS = os.path.join(MERGED_DIR, "all_embeddings.h5")

# State file to track which chunks have been processed
STATE_FILE = os.path.join(ESM2_STATE_DIR, "processed_chunks.json")

# Helper function to aggregate embedding index files dynamically
def aggregate_embeddings(wildcards):
    """
    Dynamically aggregate all embedding INDEX files (not H5).
    Following patents/clinical_trials pattern: return .index files for Qdrant insertion.
    Scans chunks directory to find which chunks exist.

    IMPORTANT: Use config directly to avoid global variable pollution from other modules!
    """
    import glob
    import sys
    from pathlib import Path

    # Wait for checkpoint to complete
    checkpoints.split_fasta_checkpoint_esm2.get(**wildcards)

    # Use config directly to avoid global variable pollution
    esm2_chunks_dir = config["esm2"]["chunks_dir"]
    esm2_embeddings_dir = config["esm2"]["embeddings_dir"]

    sys.stderr.write(f"[AGGREGATE ESM2] Using chunks_dir from config: {esm2_chunks_dir}\n")
    sys.stderr.flush()

    # Scan chunks directory for actual chunk files
    chunk_files = sorted(Path(esm2_chunks_dir).glob('chunk_*.fasta'))

    if not chunk_files:
        sys.stderr.write(f"[AGGREGATE ESM2] No chunk files found in {esm2_chunks_dir}\n")
        sys.stderr.flush()
        return []

    # Extract chunk numbers from filenames
    chunks = []
    for chunk_file in chunk_files:
        chunk_num = chunk_file.stem.split('_')[1]
        chunks.append(chunk_num)

    sys.stderr.write(f"[AGGREGATE ESM2] Found {len(chunks)} chunk files: {chunks}\n")
    sys.stderr.flush()

    # Return paths to expected FAISS index files (following patents pattern)
    return [os.path.join(esm2_embeddings_dir, f"chunk_{chunk}.index") for chunk in chunks]


# ============================================================================
# LOCAL RULES (don't submit to cluster)
# ============================================================================

localrules: esm2_all, merge_embeddings


# ============================================================================
# RULES
# ============================================================================

rule esm2_all:
    """
    Default target: FAISS indices for all chunks (no merging by default)
    Similar to patents/clinical_trials: individual chunk files ready for Qdrant
    """
    input:
        checkpoint_done = os.path.join(CHUNKS_DIR, ".split_complete"),
        indices = aggregate_embeddings  # This will return list of chunk H5 files


rule download_uniprot_esm2:
    """
    Download UniProt FASTA file (SwissProt or TrEMBL)
    Test mode: Downloads SwissProt and limits to first N sequences
    """
    output:
        fasta = RAW_FASTA
    params:
        dataset = DATASET,
        output_dir = RAW_DIR,
        limit_flag = f"--limit {esm2_config.get('test_limit_proteins', 1000)}" if TEST_MODE else "",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "esm2_download.log")
    conda:
        config["conda_env"]
    resources:
        mem_mb = esm2_config.get("download_memory_mb", 8192)
    log:
        os.path.join(LOG_DIR, "download_uniprot.log")
    shell:
        """
        python {esm2_module_scripts}/download_uniprot.py \
            --dataset {params.dataset} \
            --output-dir {params.output_dir} \
            {params.limit_flag} \
            2>&1 | tee {log}
        """


checkpoint split_fasta_checkpoint_esm2:
    """
    Split FASTA into chunks for parallel processing
    """
    input:
        RAW_FASTA
    output:
        done_marker = os.path.join(CHUNKS_DIR, ".split_complete")
    params:
        num_chunks = NUM_CHUNKS,
        output_dir = CHUNKS_DIR,
        state_file = STATE_FILE,
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "esm2_split.log")
    conda:
        config["conda_env"]
    resources:
        mem_mb = esm2_config.get("download_memory_mb", 8192)
    log:
        os.path.join(LOG_DIR, "split_fasta.log")
    shell:
        """
        # Create directories
        mkdir -p {params.output_dir}
        mkdir -p $(dirname {params.state_file})

        # Split FASTA and create state file (follows patents/clinical_trials convention)
        python {esm2_module_scripts}/split_fasta.py \
            {input} \
            {params.num_chunks} \
            {params.output_dir} \
            --state-file {params.state_file} \
            2>&1 | tee {log}

        touch {output.done_marker}
        """


rule generate_embeddings:
    """
    Generate ESM-2 embeddings and FAISS index for one chunk
    Following patents/clinical_trials pattern: creates .index and .json files
    """
    input:
        query = os.path.join(CHUNKS_DIR, "chunk_{chunk}.fasta"),
        checkpoint_done = os.path.join(CHUNKS_DIR, ".split_complete")
    output:
        index = os.path.join(EMBEDDINGS_DIR, "chunk_{chunk}.index"),
        metadata = os.path.join(EMBEDDINGS_DIR, "chunk_{chunk}.json")
    params:
        h5_file = os.path.join(EMBEDDINGS_DIR, "chunk_{chunk}.h5"),
        model = ESM_MODEL,
        batch_size = BATCH_SIZE,
        device = DEVICE,
        repr_layer = REPR_LAYER,
        max_seq_len = MAX_SEQ_LEN,
        vector_dim = esm2_config.get("vector_dimension", 1280),
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "esm2_embeddings_{chunk}.log")
    conda:
        config["conda_env"]
    threads: 4
    resources:
        mem_mb = esm2_config.get("process_memory_mb", 32768)
    log:
        os.path.join(LOG_DIR, "generate_embeddings_chunk_{chunk}.log")
    shell:
        """
        # Step 1: Generate H5 embeddings
        python {esm2_module_scripts}/generate_embeddings.py \
            {input.query} \
            {params.h5_file} \
            --model {params.model} \
            --batch-size {params.batch_size} \
            --device {params.device} \
            --repr-layer {params.repr_layer} \
            --max-seq-len {params.max_seq_len} \
            2>&1 | tee {log}

        # Step 2: Convert H5 to FAISS index + JSON metadata
        python {esm2_module_scripts}/h5_to_faiss.py \
            {params.h5_file} \
            {output.index} \
            {output.metadata} \
            --vector-dim {params.vector_dim} \
            >> {log} 2>&1
        """


rule merge_embeddings:
    """
    Merge all chunk embeddings into single file
    """
    input:
        checkpoint_done = os.path.join(CHUNKS_DIR, ".split_complete"),
        chunk_embeddings = aggregate_embeddings
    output:
        MERGED_EMBEDDINGS
    params:
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "esm2_merge.log")
    conda:
        config["conda_env"]
    resources:
        mem_mb = esm2_config.get("merge_memory_mb", 65536)
    log:
        os.path.join(LOG_DIR, "merge_embeddings.log")
    shell:
        """
        python {esm2_module_scripts}/merge_embeddings.py \
            {output} \
            {input.chunk_embeddings} \
            2>&1 | tee {log}
        """


# ============================================================================
# CLEANUP RULES (optional)
# ============================================================================

rule clean_chunks_esm2:
    """
    Remove chunk files to save space
    """
    shell:
        """
        rm -rf {CHUNKS_DIR}/*
        echo "Removed chunk files"
        """


rule clean_embeddings:
    """
    Remove individual chunk embeddings (after merging)
    """
    shell:
        """
        rm -rf {EMBEDDINGS_DIR}/chunk_*.h5
        echo "Removed chunk embedding files"
        """
