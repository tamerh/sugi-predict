# Clinical Trials Processing Configuration

# Data Directories
BASE_DATA_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/raw/clinical_trials"
PROCESSED_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/processed/clinical_trials"
FINAL_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/data/final/clinical_trials"
LOG_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/logs/clinical_trials"

# Script Directories
SCRIPTS_DIR="/data/scc/ag-gruber/GROUP/tgur/x/bioyoda/scripts/clinical_trials"

# AACT Database Settings
AACT_SNAPSHOT_URL="https://aact.ctti-clinicaltrials.org/downloads"
AACT_DATABASE_NAME="aact_clinical_trials"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="tgur"
POSTGRES_PASSWORD=""

# Processing Settings
CONDA_ENV="bioyoda"
BATCH_SIZE=1000
CHUNK_MAX_LENGTH=500

# Job Resources
DOWNLOAD_MEMORY="16G"
DOWNLOAD_RUNTIME="4:00:00"
PROCESS_MEMORY="12G"
PROCESS_RUNTIME="168:00:00"
MERGE_MEMORY="256G"
MERGE_RUNTIME="168:00:00"
CLUSTER_QUEUE="scc"

# Model Settings (same as PubMed for consistency)
MODEL_NAME="pritamdeka/S-BioBERT-snli-multinli-stsb"
VECTOR_DIMENSION=768

# Merge Settings
MERGE_METHOD="merge0"

# Debug Settings
DEBUG_SAMPLE_SIZE=100

# Text Processing Settings
MIN_TEXT_LENGTH=50
MAX_CHUNK_LENGTH=500
INCLUDE_DETAILED_DESCRIPTION=true
INCLUDE_OUTCOMES=true
INCLUDE_ELIGIBILITY=true
INCLUDE_INTERVENTIONS=true

# Quality Filters
MIN_BRIEF_SUMMARY_LENGTH=100
EXCLUDE_WITHDRAWN_STUDIES=true
EXCLUDE_UNKNOWN_STATUS=false