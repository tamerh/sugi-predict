##############################################################################
#
#   Clinical Trials Module - Snakemake Workflow
#
#   Processes ClinicalTrials.gov AACT database for semantic search
#   Pipeline: download → extract → process (no merge needed)
#
##############################################################################

import os
import glob
from datetime import datetime

# Load module-specific configuration
ct_config = config["clinical_trials"]

# Construct paths
# BASE_DIR: where outputs go (from main Snakefile)
# PROJECT_ROOT: where code lives (from main Snakefile)
BASE_DIR = config["base_dir"]
PROJECT_ROOT = config.get("project_root", os.path.dirname(os.path.dirname(os.path.dirname(workflow.snakefile))))

# Check update mode
UPDATE_MODE = config.get("update_mode", "full")

RAW_DIR = os.path.join(BASE_DIR, "raw_data", "clinical_trials")
# Use subfolder based on mode: full/ or updates/
if UPDATE_MODE == "update":
    PROCESSED_DIR = os.path.join(BASE_DIR, "data", "processed", "clinical_trials", "updates")
else:
    PROCESSED_DIR = os.path.join(BASE_DIR, "data", "processed", "clinical_trials", "full")
MERGED_DIR = os.path.join(BASE_DIR, "data", "merged", "clinical_trials")
LOG_DIR = os.path.join(BASE_DIR, "logs", "clinical_trials")
MODULE_SCRIPTS = os.path.join(PROJECT_ROOT, "modules", "clinical_trials", "scripts")  # Scripts in project root
STATE_DIR = os.path.join(BASE_DIR, "state", "clinical_trials")

# Update config with constructed paths for downstream use
ct_config["raw_dir"] = RAW_DIR
ct_config["processed_dir"] = PROCESSED_DIR
ct_config["merged_dir"] = MERGED_DIR
ct_config["log_dir"] = LOG_DIR
ct_config["trials_json"] = os.path.join(PROCESSED_DIR, "trials_data.json")
ct_config["final_index"] = os.path.join(MERGED_DIR, "clinical_trials.index")
ct_config["final_metadata"] = os.path.join(MERGED_DIR, "clinical_trials.json")

# Create directories
os.makedirs(RAW_DIR, exist_ok=True)
os.makedirs(PROCESSED_DIR, exist_ok=True)
os.makedirs(MERGED_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)
os.makedirs(STATE_DIR, exist_ok=True)

# Helper function to aggregate chunk indices after checkpoint
def aggregate_trial_chunk_indices(wildcards):
    """
    Aggregate all processed chunk index files after checkpoint completes.
    Reads from processed_chunks.json (single source of truth).
    """
    # Wait for checkpoint to complete
    checkpoints.clinical_trials_download_and_extract.get()

    import sys
    import json

    # Load processed_chunks.json from STATE_DIR
    state_dir = config["base_dir"] + "/state/clinical_trials"
    processed_chunks_path = os.path.join(state_dir, "processed_chunks.json")

    if not os.path.exists(processed_chunks_path):
        sys.stderr.write(f"[CHECKPOINT AGGREGATION] ERROR: processed_chunks.json not found at {processed_chunks_path}\n")
        sys.stderr.flush()
        return []

    with open(processed_chunks_path, 'r') as f:
        data = json.load(f)

    sys.stderr.write(f"[CHECKPOINT AGGREGATION] Loaded processed_chunks.json\n")
    sys.stderr.flush()

    # Check if no changes in update mode
    if data.get('no_changes', False):
        sys.stderr.write(f"[CHECKPOINT AGGREGATION] No changes detected - nothing to process\n")
        sys.stderr.flush()
        return []

    # Get chunks that need processing (status: ready_to_process or completed)
    chunks_dict = data.get('chunks', {})
    if not chunks_dict:
        sys.stderr.write(f"[CHECKPOINT AGGREGATION] No chunks found\n")
        sys.stderr.flush()
        return []

    ct_processed_dir = config["clinical_trials"]["processed_dir"]
    indices = []

    for chunk_filename, chunk_info in chunks_dict.items():
        # Convert .json to .index
        chunk_index_name = chunk_filename.replace('.json', '.index')
        chunk_index_path = os.path.join(ct_processed_dir, chunk_index_name)
        indices.append(chunk_index_path)
        sys.stderr.write(f"[CHECKPOINT AGGREGATION]   -> {chunk_index_path}\n")

    sys.stderr.write(f"[CHECKPOINT AGGREGATION] Total chunks to process: {len(indices)}\n")
    sys.stderr.flush()
    return indices


# Top-level rule for clinical_trials module
# Default: produces chunk indices only (NO merge)
# Similar to PubMed: individual files ready for Qdrant insertion
# IMPORTANT: Depends on checkpoint done_marker to trigger it
# Note: processed_chunks.json is read directly by aggregate function, not as Snakemake input
rule clinical_trials_all:
    input:
        checkpoint_done = os.path.join(STATE_DIR, ".download_extract_done"),
        indices = aggregate_trial_chunk_indices

# Completion marker for Qdrant dependency
# Note: processed_chunks.json is read directly in shell, not as Snakemake input
rule clinical_trials_processing_complete:
    input:
        indices = aggregate_trial_chunk_indices
    output:
        done = os.path.join(PROCESSED_DIR, ".processing_complete")
    params:
        processed_dir = PROCESSED_DIR,
        state_file = os.path.join(STATE_DIR, "processed_chunks.json"),
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "clinical_trials_processing_complete.log")
    shell:
        """
        # Check if this is a no-changes scenario
        NO_CHANGES=$(python -c "import json; data = json.load(open('{params.state_file}')); print(data.get('no_changes', False))" 2>/dev/null || echo "False")

        # Count actual index files created
        INDEX_COUNT=$(find {params.processed_dir} -name "*.index" 2>/dev/null | wc -l)

        echo "Clinical Trials FAISS processing complete" > {output.done}
        echo "Processed chunk files: $INDEX_COUNT" >> {output.done}
        echo "Index files from input: $(echo {input.indices} | wc -w)" >> {output.done}
        echo "Completed at: $(date)" >> {output.done}

        if [ "$NO_CHANGES" = "True" ]; then
            echo "Update mode: No changes detected - nothing to process" >> {output.done}
            exit 0
        fi

        if [ "$INDEX_COUNT" -eq 0 ]; then
            echo "ERROR: No index files were created!" | tee -a {output.done}
            exit 1
        fi
        """

# Combined checkpoint: Download + Extract (Single source of truth: processed_chunks.json)
# Note: This checkpoint ALWAYS runs - bioyoda.sh deletes the output marker before each run
# IMPORTANT: processed_chunks.json is NOT an output - script creates it as side effect
# This prevents Snakemake from deleting it on re-runs
checkpoint clinical_trials_download_and_extract:
    output:
        done_marker = os.path.join(STATE_DIR, ".download_extract_done")
    params:
        script = os.path.join(MODULE_SCRIPTS, "download_and_extract.py"),
        download_dir = RAW_DIR,
        extract_dir = os.path.join(RAW_DIR, "extracted"),
        processed_dir = PROCESSED_DIR,
        state_file = os.path.join(STATE_DIR, "processed_chunks.json"),
        tracking_db = ct_config.get("update", {}).get("tracking_db", os.path.join(STATE_DIR, "trials_tracking.db")),
        min_summary_length = ct_config.get("min_summary_length", 100),
        chunk_size = ct_config.get("trials_per_chunk", 0) if ct_config.get("enable_chunking", False) else 0,
        include_flags = (
            ("--include-detailed-description " if ct_config.get("include_detailed_description", True) else "") +
            ("--include-outcomes " if ct_config.get("include_outcomes", True) else "") +
            ("--include-eligibility " if ct_config.get("include_eligibility", True) else "") +
            ("--include-interventions " if ct_config.get("include_interventions", True) else "") +
            ("--exclude-withdrawn " if ct_config.get("exclude_withdrawn", True) else "")
        ),
        limit_flag = f"--limit {ct_config['test_trials_limit']}" if ct_config.get("test_mode", False) else "",
        nct_ids_flag = f"--nct-ids-file {os.path.join(PROJECT_ROOT, ct_config['test_nct_ids_file'])}" if (ct_config.get("test_mode", False) and ct_config.get("test_nct_ids_file")) else "",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "clinical_trials_download_extract.log")
    log:
        os.path.join(LOG_DIR, "download_and_extract.log")
    conda:
        config["conda_env"]
    threads: 1
    resources:
        mem_mb=ct_config["extract_memory_mb"]
    shell:
        """
        # Backup previous log
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}
        echo "Snakemake mode: {UPDATE_MODE}" >> {log}
        echo "Checkpoint triggered (output marker deleted by bioyoda.sh)" >> {log}
        echo "" >> {log}

        # IMPORTANT: Always run the script (it's idempotent)
        # This ensures Snakemake doesn't skip the checkpoint
        echo "Running combined download_and_extract.py script..." >> {log}
        echo "The script is IDEMPOTENT - it automatically determines what to do:" >> {log}
        echo "  - No state file → Fresh run (process everything)" >> {log}
        echo "  - State file exists, last_update == today → Skip (nothing to do)" >> {log}
        echo "  - State file exists, last_update != today → Update (incremental)" >> {log}
        echo "" >> {log}

        python {params.script} \
            --download-dir {params.download_dir} \
            --extract-dir {params.extract_dir} \
            --output-json {params.processed_dir}/trials_data.json \
            --processed-chunks-output {params.state_file} \
            --tracking-db {params.tracking_db} \
            --min-summary-length {params.min_summary_length} \
            --chunk-size {params.chunk_size} \
            {params.include_flags} \
            {params.limit_flag} \
            {params.nct_ids_flag} \
            >> {log} 2>&1

        EXIT_CODE=$?

        if [ $EXIT_CODE -ne 0 ]; then
            echo "" >> {log}
            echo "ERROR: Script failed with exit code $EXIT_CODE" >> {log}
            exit 1
        fi

        # Create done marker for Snakemake (processed_chunks.json created by script as side effect)
        touch {output.done_marker}

        echo "" >> {log}
        echo "==================== COMPLETED: $(date) ====================" >> {log}
        """

# Rule 3a: Process individual chunk (for chunked mode)
# Handles both patterns: trials_chunk_XXXX and trials_update_YYYYMMDD_chunk_XXXX
rule clinical_trials_process_chunk:
    input:
        chunk_json = os.path.join(RAW_DIR, "chunked", "{chunk_name}.json")
    output:
        index = os.path.join(PROCESSED_DIR, "{chunk_name}.index"),
        metadata = os.path.join(PROCESSED_DIR, "{chunk_name}.json")  # Consistent naming: .index + .json
    params:
        script = os.path.join(MODULE_SCRIPTS, "process_trials_chunk.py"),
        tracking_script = os.path.join(MODULE_SCRIPTS, "chunk_tracking.py"),
        chunk_tracking_file = ct_config.get("update", {}).get("chunk_tracking_file", os.path.join(STATE_DIR, "processed_chunks.json")),
        model = ct_config["model_name"],
        vector_dim = ct_config["vector_dimension"],
        encode_batch_size = ct_config.get("encode_batch_size", 128),
        num_workers = ct_config.get("num_workers", 1),
        max_chunk_length = ct_config.get("max_chunk_length", 500),
        min_text_length = ct_config.get("min_text_length", 50),
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "clinical_trials_process_chunk.{chunk_name}.log")
    log:
        os.path.join(LOG_DIR, "process_chunk_{chunk_name}.log")
    conda:
        config["conda_env"]
    threads: ct_config.get("num_workers", 1)
    resources:
        mem_mb=ct_config["process_memory_mb"]
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}
        echo "Processing chunk {wildcards.chunk_name}..." >> {log}

        python {params.script} \
            --input-json {input.chunk_json} \
            --output-index {output.index} \
            --output-metadata {output.metadata} \
            --model-name {params.model} \
            --vector-dimension {params.vector_dim} \
            --encode-batch-size {params.encode_batch_size} \
            --num-workers {params.num_workers} \
            --max-chunk-length {params.max_chunk_length} \
            --min-text-length {params.min_text_length} \
            >> {log} 2>&1

        # Extract chunk name from input file
        CHUNK_NAME=$(basename {input.chunk_json})

        # Count vectors in generated metadata file
        VECTOR_COUNT=$(python -c "import json; data = json.load(open('{output.metadata}')); print(len(data))")

        echo "Chunk processing completed successfully" >> {log}
        echo "Index: {output.index}" >> {log}
        echo "Vectors generated: $VECTOR_COUNT" >> {log}

        # Mark chunk as processed in tracking file
        echo "Marking chunk as processed in tracking file..." >> {log}
        python {params.tracking_script} \
            --tracking-file {params.chunk_tracking_file} \
            mark "$CHUNK_NAME" \
            --vectors "$VECTOR_COUNT" \
            >> {log} 2>&1

        echo "Chunk marked as processed in tracking" >> {log}
        """

# Rule 3b: Process single file (for non-chunked mode, backward compatibility)
rule clinical_trials_process_single:
    input:
        trials_json = ct_config["trials_json"]
    output:
        index = os.path.join(PROCESSED_DIR, "clinical_trials_single.index"),
        metadata = os.path.join(PROCESSED_DIR, "clinical_trials_single.json")
    params:
        script = os.path.join(MODULE_SCRIPTS, "process_trials.py"),
        model = ct_config["model_name"],
        vector_dim = ct_config["vector_dimension"],
        batch_size = ct_config.get("batch_size", 1000),
        encode_batch_size = ct_config.get("encode_batch_size", 128),
        num_workers = ct_config.get("num_workers", 1),
        max_chunk_length = ct_config.get("max_chunk_length", 500),
        min_text_length = ct_config.get("min_text_length", 50),
        limit_flag = f"--limit {ct_config['test_trials_limit']}" if ct_config.get("test_mode", False) else "",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "clinical_trials_process.log")
    log:
        os.path.join(LOG_DIR, "process.log")
    conda:
        config["conda_env"]
    threads: ct_config.get("num_workers", 1)
    resources:
        mem_mb=ct_config["process_memory_mb"]
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}

        echo "Starting clinical trials processing..." >> {log}

        python {params.script} \
            --input-json {input.trials_json} \
            --output-index {output.index} \
            --output-metadata {output.metadata} \
            --model-name {params.model} \
            --vector-dimension {params.vector_dim} \
            --batch-size {params.batch_size} \
            --encode-batch-size {params.encode_batch_size} \
            --num-workers {params.num_workers} \
            --max-chunk-length {params.max_chunk_length} \
            --min-text-length {params.min_text_length} \
            {params.limit_flag} \
            >> {log} 2>&1

        echo "Processing completed successfully" >> {log}
        echo "Final index: {output.index}" >> {log}
        echo "Final metadata: {output.metadata}" >> {log}
        echo "Index size: $(du -h {output.index})" >> {log}
        """

# Rule 3c: OPTIONAL - Merge chunked indices into single master index
# This is NOT run by default (like pubmed_merge)
# Only run explicitly if you need a single merged index for analysis
rule clinical_trials_merge:
    input:
        chunk_indices = aggregate_trial_chunk_indices
    output:
        index = os.path.join(MERGED_DIR, "master_clinical_trials.index"),
        metadata = os.path.join(MERGED_DIR, "master_clinical_trials.json")
    params:
        script = os.path.join(MODULE_SCRIPTS, "merge_trials.py"),
        processed_dir = PROCESSED_DIR,
        vector_dim = ct_config["vector_dimension"],
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "clinical_trials_merge.log")
    log:
        os.path.join(LOG_DIR, "merge.log")
    conda:
        config["conda_env"]
    threads: 1
    resources:
        mem_mb=ct_config.get("merge_memory_mb", 32768)
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}
        echo "Starting merge of $(echo {input.chunk_indices} | wc -w) chunk files..." >> {log}

        # Check if we're in chunked mode or single file mode
        NUM_INPUTS=$(echo {input.chunk_indices} | wc -w)

        if [ "$NUM_INPUTS" -eq 1 ]; then
            # Single file mode - just copy the file
            echo "Single file mode detected - copying files directly" >> {log}
            SINGLE_INDEX=$(echo {input.chunk_indices} | awk '{{print $1}}')
            SINGLE_METADATA=${{SINGLE_INDEX%.index}}.json

            cp "$SINGLE_INDEX" {output.index} >> {log} 2>&1
            cp "$SINGLE_METADATA" {output.metadata} >> {log} 2>&1

            echo "Files copied successfully" >> {log}
        else
            # Chunked mode - run merge script
            echo "Chunked mode detected - running merge script" >> {log}

            python {params.script} \
                --processed-dir {params.processed_dir} \
                --output-index {output.index} \
                --output-metadata {output.metadata} \
                --vector-dim {params.vector_dim} \
                >> {log} 2>&1

            echo "Merge completed successfully" >> {log}
        fi

        echo "Final index size: $(du -h {output.index})" >> {log}
        echo "Final metadata size: $(du -h {output.metadata})" >> {log}
        """

# Rule 4: OPTIONAL - Validate merged master index
# Only applies if you ran clinical_trials_merge
rule clinical_trials_validate:
    input:
        index = os.path.join(MERGED_DIR, "master_clinical_trials.index"),
        metadata = os.path.join(MERGED_DIR, "master_clinical_trials.json")
    output:
        validation_report = os.path.join(MERGED_DIR, "validation_report.txt")
    params:
        vector_dim = ct_config["vector_dimension"],
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "clinical_trials_validate.log")
    log:
        os.path.join(LOG_DIR, "validate.log")
    conda:
        config["conda_env"]
    shell:
        """
        # Backup previous log if it exists
        if [ -f {log} ]; then
            mv {log} {log}.$(date +%Y%m%d_%H%M%S).bak
        fi

        echo "==================== RUN STARTED: $(date) ====================" > {log}

        echo "Validating clinical trials indices..." >> {log}

        python -c "
import faiss
import json
import sys

try:
    # Load index
    index = faiss.read_index('{input.index}')
    print(f'Index loaded: {{index.ntotal}} vectors, dimension={{index.d}}')

    # Validate dimension
    if index.d != {params.vector_dim}:
        print(f'ERROR: Dimension mismatch! Expected {params.vector_dim}, got {{index.d}}')
        sys.exit(1)

    # Load metadata
    with open('{input.metadata}', 'r') as f:
        metadata = json.load(f)
    print(f'Metadata loaded: {{len(metadata)}} entries')

    # Validate counts match
    if len(metadata) != index.ntotal:
        print(f'ERROR: Count mismatch! Index has {{index.ntotal}} vectors, metadata has {{len(metadata)}} entries')
        sys.exit(1)

    print('✓ Validation passed!')
    print(f'  Total vectors: {{index.ntotal}}')
    print(f'  Dimension: {{index.d}}')
    print(f'  Metadata entries: {{len(metadata)}}')

except Exception as e:
    print(f'ERROR: Validation failed: {{e}}')
    sys.exit(1)
        " > {output.validation_report} 2>&1

        cat {output.validation_report} >> {log}
        echo "Validation completed" >> {log}
        """
