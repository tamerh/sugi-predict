import sys
import os

# Load configuration
configfile: "config/config.yaml"

# Local rules (don't submit to cluster)
localrules: all, pubmed, clinical_trials

# Create logging directory
os.makedirs(config["logs_dir"], exist_ok=True)

# Utility function for resource estimation (adapted from tieri)
def estimate_mb_required(file_path, size_factor=8000, min_mb=8000, max_mb=30000):
    """
    Return mb_required for mem_mb based on the size of input files
    Args:
        file_path: path to file to estimate resources from
        size_factor: multiplication factor (default 8000)
        min_mb: minimum memory in MB (default 8GB)
        max_mb: maximum memory in MB (default 30GB)
    """
    if os.path.exists(file_path):
        mb_required = os.path.getsize(file_path) / (1024**2)
        if mb_required < min_mb:
            mb_required = min_mb
        elif mb_required > max_mb:
            mb_required = max_mb
        return int(mb_required)
    else:
        return int(size_factor)

# Include module workflows (data processing only)
include: "pubmed/Snakefile"
include: "clinical_trials/Snakefile"

# Top-level target: build all data modules
rule all:
    input:
        rules.pubmed_all.input,
        rules.clinical_trials_all.input

# Individual module targets (data processing only)
rule pubmed:
    input:
        rules.pubmed_all.input

rule clinical_trials:
    input:
        rules.clinical_trials_all.input

##############################################################################
# Pipeline Completion Handlers
##############################################################################

onsuccess:
    print("\n" + "="*80, file=sys.stderr)
    print("Data processing pipeline completed successfully!", file=sys.stderr)
    print("="*80, file=sys.stderr)

onerror:
    print("\n" + "="*80, file=sys.stderr)
    print("Pipeline failed!", file=sys.stderr)
    print("="*80, file=sys.stderr)
