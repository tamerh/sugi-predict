import os
import glob
from datetime import datetime

# Generate timestamp for this run (all logs will use same timestamp)
RUN_TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")

# Load module-specific configuration
patents_config = config["patents"]

# Construct paths
BASE_DIR = config["base_dir"]
PROJECT_ROOT = config.get("project_root", os.path.dirname(os.path.dirname(os.path.dirname(workflow.snakefile))))

# Check update mode
UPDATE_MODE = config.get("update_mode", "full")

RAW_DIR = os.path.join(BASE_DIR, "raw_data", "patents", "surechembl")
USPTO_RAW_DIR = os.path.join(BASE_DIR, "raw_data", "patents", "uspto")
PROCESSED_DIR = os.path.join(BASE_DIR, "data", "processed", "patents")
TEXT_DIR = os.path.join(PROCESSED_DIR, "text")
COMPOUNDS_DIR = os.path.join(PROCESSED_DIR, "compounds")
BIOBTREE_DIR = os.path.join(PROCESSED_DIR, "biobtree")
LOG_DIR = os.path.join(BASE_DIR, "logs", "patents")
MODULE_SCRIPTS = os.path.join(PROJECT_ROOT, "modules", "patents", "scripts")
STATE_DIR = os.path.join(BASE_DIR, "state", "patents")

# Update config with constructed paths for downstream use
patents_config["raw_dir"] = RAW_DIR
patents_config["processed_dir"] = PROCESSED_DIR
patents_config["text_dir"] = TEXT_DIR
patents_config["compounds_dir"] = COMPOUNDS_DIR
patents_config["biobtree_dir"] = BIOBTREE_DIR
patents_config["log_dir"] = LOG_DIR

# Create directories
os.makedirs(RAW_DIR, exist_ok=True)
os.makedirs(PROCESSED_DIR, exist_ok=True)
os.makedirs(TEXT_DIR, exist_ok=True)
os.makedirs(COMPOUNDS_DIR, exist_ok=True)
os.makedirs(BIOBTREE_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)
os.makedirs(STATE_DIR, exist_ok=True)

# Chunked compounds directory (matching chunked patents pattern)
COMPOUNDS_CHUNKED_DIR = os.path.join(BASE_DIR, "raw_data", "patents", "chunked_compounds")
os.makedirs(COMPOUNDS_CHUNKED_DIR, exist_ok=True)

# Helper function to get latest release directory
def get_latest_release():
    """Get the latest release directory from raw data."""
    if not os.path.exists(RAW_DIR):
        return None

    # Find all release directories (YYYY-MM-DD format)
    releases = []
    for item in os.listdir(RAW_DIR):
        release_path = os.path.join(RAW_DIR, item)
        if os.path.isdir(release_path):
            try:
                # Validate it's a date format
                datetime.strptime(item, '%Y-%m-%d')
                releases.append(item)
            except ValueError:
                continue

    if not releases:
        return None

    # Return newest release
    releases.sort(reverse=True)
    return releases[0]

# Helper function to get release-specific paths
def get_release_paths():
    """Get paths for the latest release."""
    release = get_latest_release()
    if not release:
        # If no release exists, use a wildcard pattern for Snakemake to handle
        # The download script will determine the actual latest release
        release = "{release}"

    release_dir = os.path.join(RAW_DIR, release)

    return {
        'release': release,
        'release_dir': release_dir,
        'patents_parquet': os.path.join(release_dir, 'patents.parquet'),
        'compounds_parquet': os.path.join(release_dir, 'compounds.parquet'),
        'map_parquet': os.path.join(release_dir, 'patent_compound_map.parquet'),
        'fields_parquet': os.path.join(release_dir, 'fields.parquet')
    }

# Get paths for current release
RELEASE_PATHS = get_release_paths()

# Helper function to aggregate patent chunk indices after checkpoint
def aggregate_patent_chunk_indices(wildcards):
    """
    Aggregate all processed chunk index files after checkpoint completes.
    Reads from processed_chunks.json (single source of truth).
    Similar to clinical_trials pattern.
    """
    # Wait for checkpoint to complete
    checkpoints.patents_download_checkpoint.get()

    import sys
    import json

    # Load processed_chunks.json from STATE_DIR
    state_file = os.path.join(STATE_DIR, "processed_chunks.json")

    if not os.path.exists(state_file):
        sys.stderr.write(f"[CHECKPOINT AGGREGATION] ERROR: processed_chunks.json not found at {state_file}\n")
        sys.stderr.flush()
        return []

    with open(state_file, 'r') as f:
        data = json.load(f)

    sys.stderr.write(f"[CHECKPOINT AGGREGATION] Loaded processed_chunks.json\n")
    sys.stderr.flush()

    # Get chunks that need processing
    chunks_dict = data.get('chunks', {})
    if not chunks_dict:
        sys.stderr.write(f"[CHECKPOINT AGGREGATION] No chunks found\n")
        sys.stderr.flush()
        return []

    indices = []
    for chunk_filename, chunk_info in chunks_dict.items():
        # Convert .parquet to .index (chunks are parquet, processed indices are .index)
        chunk_index_name = chunk_filename.replace('.parquet', '.index')
        chunk_index_path = os.path.join(TEXT_DIR, chunk_index_name)
        indices.append(chunk_index_path)
        sys.stderr.write(f"[CHECKPOINT AGGREGATION]   -> {chunk_index_path}\n")

    sys.stderr.write(f"[CHECKPOINT AGGREGATION] Total chunks to process: {len(indices)}\n")
    sys.stderr.flush()
    return indices

# Helper function to aggregate compound chunk indices after checkpoint
def aggregate_compound_chunk_indices(wildcards):
    """
    Aggregate all processed compound chunk index files after checkpoint completes.
    Similar to aggregate_patent_chunk_indices but for compounds.
    """
    # Wait for checkpoint to complete
    checkpoints.patents_download_checkpoint.get()

    import sys
    import json

    # Load processed_compounds_chunks.json from STATE_DIR
    state_file = os.path.join(STATE_DIR, "processed_compounds_chunks.json")

    if not os.path.exists(state_file):
        sys.stderr.write(f"[COMPOUNDS AGGREGATION] WARNING: processed_compounds_chunks.json not found at {state_file}\n")
        sys.stderr.write(f"[COMPOUNDS AGGREGATION] Compounds chunking may not have been enabled or completed\n")
        sys.stderr.flush()
        return []

    with open(state_file, 'r') as f:
        data = json.load(f)

    sys.stderr.write(f"[COMPOUNDS AGGREGATION] Loaded processed_compounds_chunks.json\n")
    sys.stderr.flush()

    # Get chunks that need processing
    chunks_dict = data.get('chunks', {})
    if not chunks_dict:
        sys.stderr.write(f"[COMPOUNDS AGGREGATION] No chunks found\n")
        sys.stderr.flush()
        return []

    indices = []
    for chunk_filename, chunk_info in chunks_dict.items():
        # Convert .parquet to .index (chunks are parquet, processed indices are .index)
        chunk_index_name = chunk_filename.replace('.parquet', '.index')
        chunk_index_path = os.path.join(COMPOUNDS_DIR, chunk_index_name)
        indices.append(chunk_index_path)
        sys.stderr.write(f"[COMPOUNDS AGGREGATION]   -> {chunk_index_path}\n")

    sys.stderr.write(f"[COMPOUNDS AGGREGATION] Total compound chunks to process: {len(indices)}\n")
    sys.stderr.flush()
    return indices

# Unified download rule - handles both SureChEMBL and USPTO (if enabled)
# CHECKPOINT: Creates processed_chunks.json as side effect (NOT as Snakemake output)
# Similar to clinical_trials: only done_marker is output
checkpoint patents_download_checkpoint:
    output:
        done_marker = os.path.join(STATE_DIR, ".download_complete")
    params:
        script = os.path.join(MODULE_SCRIPTS, "download_and_prepare_patents.py"),
        surechembl_raw_dir = RAW_DIR,
        uspto_raw_dir = USPTO_RAW_DIR,
        state_dir = STATE_DIR,
        # SureChEMBL options
        update_flag = "--surechembl-update-mode" if UPDATE_MODE == "update" else "",
        limit_flag = f"--surechembl-limit-files {patents_config.get('test_limit_files', 4)}" if patents_config.get("test_mode", False) else "",
        # USPTO options
        enable_uspto = "--enable-uspto" if patents_config.get("enable_uspto", False) else "",
        uspto_historical_json_dir = os.path.join(BASE_DIR, patents_config.get("uspto_historical_json_dir", "")) if patents_config.get("uspto_historical_json_dir") else "",
        uspto_limit_flag = f"--uspto-limit-files {patents_config.get('test_limit_files', 4)}" if patents_config.get("test_mode", False) else "",
        uspto_test_flag = "--uspto-test-mode" if patents_config.get("test_mode", False) else "",
        # Chunking options
        chunk_size = patents_config.get("patents_per_chunk", 0),
        compounds_chunk_size = patents_config.get("compounds_per_chunk", 1000000),
        limit = patents_config.get("test_limit_patents", 0) if patents_config.get("test_mode", False) else 0,
        compounds_limit = patents_config.get("test_limit_compounds", 0) if patents_config.get("test_mode", False) else 0,
        state_file = os.path.join(STATE_DIR, "processed_chunks.json"),
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "patents_download.log")
    log:
        os.path.join(LOG_DIR, f"download_{RUN_TIMESTAMP}.log")
    conda:
        config["conda_env"]
    threads: 1
    resources:
        mem_mb=patents_config.get("download_memory_mb", 16384)
    shell:
        """
        echo "==================== UNIFIED DOWNLOAD STARTED: $(date) ====================" > {log}

        python {params.script} \
            --surechembl-raw-dir {params.surechembl_raw_dir} \
            --uspto-raw-dir {params.uspto_raw_dir} \
            --state-dir {params.state_dir} \
            {params.update_flag} \
            {params.limit_flag} \
            {params.enable_uspto} \
            --uspto-historical-json-dir {params.uspto_historical_json_dir} \
            {params.uspto_limit_flag} \
            {params.uspto_test_flag} \
            --chunk-size {params.chunk_size} \
            --compounds-chunk-size {params.compounds_chunk_size} \
            --processed-chunks-output {params.state_file} \
            --limit {params.limit} \
            --compounds-limit {params.compounds_limit} \
            >> {log} 2>&1

        EXIT_CODE=$?

        if [ $EXIT_CODE -ne 0 ]; then
            echo "ERROR: Download pipeline failed with exit code $EXIT_CODE" >> {log}
            exit 1
        fi

        # Create done marker for Snakemake (processed_chunks.json created by script as side effect)
        touch {output.done_marker}

        echo "==================== UNIFIED DOWNLOAD COMPLETED: $(date) ====================" >> {log}
        """

# Function to get downloaded release after checkpoint
def get_downloaded_release_files(wildcards):
    """Get the actual downloaded files after download checkpoint completes."""
    # This function is called after the checkpoint completes
    # Re-evaluate which release was actually downloaded
    release = get_latest_release()

    # During DAG building (before download), release might not exist yet
    # Use a placeholder that will be resolved after checkpoint
    if not release:
        # Return placeholder paths - these will be resolved after checkpoint runs
        release = "PLACEHOLDER"

    release_dir = os.path.join(RAW_DIR, release)

    # USPTO historical parquet path (single file, not release-specific)
    # This is auto-generated from JSON files if it doesn't exist
    uspto_historical_dir_config = patents_config.get("uspto_historical_json_dir", "")
    uspto_historical_dir = os.path.join(BASE_DIR, uspto_historical_dir_config) if uspto_historical_dir_config else ""
    uspto_historical_file = os.path.join(uspto_historical_dir, "uspto_historical.parquet") if uspto_historical_dir else ""

    return {
        'patents': os.path.join(release_dir, 'patents.parquet'),
        'compounds': os.path.join(release_dir, 'compounds.parquet'),
        'map_file': os.path.join(release_dir, 'patent_compound_map.parquet'),
        'fields': os.path.join(release_dir, 'fields.parquet'),
        'uspto_historical': uspto_historical_file
    }

# Top-level rule for patents module
# Default: produces chunk indices only (NO merge) + compounds index
# Similar to clinical_trials: individual chunk files ready for Qdrant insertion
# IMPORTANT: Depends on checkpoint done_marker to trigger it
rule patents_all:
    input:
        checkpoint_done = os.path.join(STATE_DIR, ".download_complete"),
        indices = aggregate_patent_chunk_indices,
        compounds_indices = aggregate_compound_chunk_indices  # Changed to chunked processing

# Compounds-only rule (for CPU processing while text runs on GPU)
rule patents_compounds_only:
    input:
        checkpoint_done = os.path.join(STATE_DIR, ".download_complete"),
        compounds_indices = aggregate_compound_chunk_indices

# Text-only rule (for GPU processing on Colab)
rule patents_text_only:
    input:
        checkpoint_done = os.path.join(STATE_DIR, ".download_complete"),
        indices = aggregate_patent_chunk_indices

# Rule 2a: Process individual patent chunk (text embeddings with USPTO enrichment)
rule patents_process_chunk:
    input:
        chunk_file = os.path.join(BASE_DIR, "raw_data", "patents", "chunked", "{chunk_name}.parquet")
    output:
        index = os.path.join(TEXT_DIR, "{chunk_name}.index"),
        metadata = os.path.join(TEXT_DIR, "{chunk_name}.json")
    params:
        script = os.path.join(MODULE_SCRIPTS, "process_patents.py"),
        tracking_script = os.path.join(PROJECT_ROOT, "modules", "clinical_trials", "scripts", "chunk_tracking.py"),
        chunk_tracking_file = os.path.join(STATE_DIR, "processed_chunks.json"),
        model = patents_config.get("model_name", "pritamdeka/S-BioBERT-snli-multinli-stsb"),
        vector_dim = patents_config.get("vector_dimension", 768),
        encode_batch_size = patents_config.get("encode_batch_size", 128),
        num_workers = patents_config.get("num_workers", 1),
        max_chunk_length = patents_config.get("max_chunk_length", 500),
        min_text_length = patents_config.get("min_text_length", 50),
        uspto_historical = lambda wildcards, input: get_downloaded_release_files(wildcards).get('uspto_historical', ''),
        uspto_flag = "--uspto-data" if patents_config.get("enable_uspto", False) else "",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", f"patents_process_chunk_{{chunk_name}}.log")
    log:
        os.path.join(LOG_DIR, f"process_chunk_{{chunk_name}}_{RUN_TIMESTAMP}.log")
    conda:
        config["conda_env"]
    threads: patents_config.get("num_workers", 1)
    resources:
        mem_mb=patents_config.get("process_memory_mb", 16384)  # Reduced per-chunk memory
    shell:
        """
        echo "==================== PROCESS CHUNK {wildcards.chunk_name} STARTED: $(date) ====================" > {log}

        # Build command with optional USPTO enrichment
        CMD="python {params.script} \
            --input {input.chunk_file} \
            --output-index {output.index} \
            --output-metadata {output.metadata} \
            --model-name {params.model} \
            --vector-dimension {params.vector_dim} \
            --encode-batch-size {params.encode_batch_size} \
            --num-workers {params.num_workers} \
            --max-chunk-length {params.max_chunk_length} \
            --min-text-length {params.min_text_length}"

        # Add USPTO historical data if enabled and file exists
        if [ -f "{params.uspto_historical}" ] && [ "{params.uspto_flag}" != "" ]; then
            echo "USPTO enrichment enabled: {params.uspto_historical}" >> {log}
            CMD="$CMD {params.uspto_flag} {params.uspto_historical}"
        else
            echo "USPTO enrichment disabled or file not found" >> {log}
        fi

        echo "Running command: $CMD" >> {log}
        eval "$CMD" >> {log} 2>&1

        EXIT_CODE=$?

        if [ $EXIT_CODE -ne 0 ]; then
            echo "ERROR: Chunk processing failed with exit code $EXIT_CODE" >> {log}
            exit 1
        fi

        # Count vectors
        VECTOR_COUNT=$(python -c "import json; data = json.load(open('{output.metadata}')); print(len(data))" 2>/dev/null || echo "0")
        echo "Vectors generated: $VECTOR_COUNT" >> {log}

        # Extract chunk name for tracking (add .parquet extension)
        CHUNK_NAME="{wildcards.chunk_name}.parquet"

        # Mark chunk as processed in tracking file
        echo "Marking chunk as processed in tracking file..." >> {log}
        python {params.tracking_script} \
            --tracking-file {params.chunk_tracking_file} \
            mark "$CHUNK_NAME" \
            --vectors "$VECTOR_COUNT" \
            >> {log} 2>&1

        echo "Chunk marked as processed in tracking" >> {log}

        echo "==================== PROCESS CHUNK {wildcards.chunk_name} COMPLETED: $(date) ====================" >> {log}
        """

# Rule 2b: Process patents for text embeddings (DEPRECATED - replaced by chunked processing)
# This rule is kept for backward compatibility with non-chunked mode (chunk_size=0)
rule patents_process_text:
    output:
        index = os.path.join(TEXT_DIR, "patents_text.index"),
        metadata = os.path.join(TEXT_DIR, "patents_text.json")
    params:
        script = os.path.join(MODULE_SCRIPTS, "process_patents.py"),
        model = patents_config.get("model_name", "pritamdeka/S-BioBERT-snli-multinli-stsb"),
        vector_dim = patents_config.get("vector_dimension", 768),
        encode_batch_size = patents_config.get("encode_batch_size", 128),
        num_workers = patents_config.get("num_workers", 1),
        max_chunk_length = patents_config.get("max_chunk_length", 500),
        min_text_length = patents_config.get("min_text_length", 50),
        limit_flag = f"--limit {patents_config.get('test_limit_patents', 100)}" if patents_config.get("test_mode", False) and not patents_config.get("test_patent_ids_file") else "",
        # Input files determined after checkpoint
        patents_file = lambda wildcards, input: get_downloaded_release_files(wildcards)['patents'],
        uspto_historical = lambda wildcards, input: get_downloaded_release_files(wildcards)['uspto_historical'],
        uspto_flag = "--uspto-data" if patents_config.get("enable_uspto", False) else "",
        patent_ids_file = os.path.join(PROJECT_ROOT, patents_config["test_patent_ids_file"]) if (patents_config.get("test_mode", False) and patents_config.get("test_patent_ids_file")) else "",
        patent_ids_flag = "--patent-ids-file" if (patents_config.get("test_mode", False) and patents_config.get("test_patent_ids_file")) else "",
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", "patents_process_text.log")
    log:
        os.path.join(LOG_DIR, f"process_text_{RUN_TIMESTAMP}.log")
    conda:
        config["conda_env"]
    threads: patents_config.get("num_workers", 1)
    resources:
        mem_mb=patents_config.get("process_memory_mb", 20480)  # Increased to 20GB for USPTO data
    shell:
        """
        echo "==================== PROCESS TEXT STARTED: $(date) ====================" > {log}

        # Build command with optional USPTO enrichment
        CMD="python {params.script} \
            --input {params.patents_file} \
            --output-index {output.index} \
            --output-metadata {output.metadata} \
            --model-name {params.model} \
            --vector-dimension {params.vector_dim} \
            --encode-batch-size {params.encode_batch_size} \
            --num-workers {params.num_workers} \
            --max-chunk-length {params.max_chunk_length} \
            --min-text-length {params.min_text_length} \
            {params.limit_flag}"

        # Add patent IDs file filter if enabled (for testing enrichment)
        if [ -f "{params.patent_ids_file}" ] && [ "{params.patent_ids_flag}" != "" ]; then
            echo "Patent IDs filter enabled: {params.patent_ids_file}" >> {log}
            CMD="$CMD {params.patent_ids_flag} {params.patent_ids_file}"
        fi

        # Add USPTO historical data if enabled and file exists
        if [ -f "{params.uspto_historical}" ] && [ "{params.uspto_flag}" != "" ]; then
            echo "USPTO enrichment enabled: {params.uspto_historical}" >> {log}
            CMD="$CMD {params.uspto_flag} {params.uspto_historical}"
        else
            echo "USPTO enrichment disabled or file not found" >> {log}
        fi

        echo "Running command: $CMD" >> {log}
        eval "$CMD" >> {log} 2>&1

        EXIT_CODE=$?

        if [ $EXIT_CODE -ne 0 ]; then
            echo "ERROR: Text processing failed with exit code $EXIT_CODE" >> {log}
            exit 1
        fi

        # Count vectors
        VECTOR_COUNT=$(python -c "import json; data = json.load(open('{output.metadata}')); print(len(data))" 2>/dev/null || echo "0")
        echo "Vectors generated: $VECTOR_COUNT" >> {log}

        echo "==================== PROCESS TEXT COMPLETED: $(date) ====================" >> {log}
        """

# Rule 3: Process individual compound chunk (chemical fingerprints)
# Similar to patents_process_chunk but for compounds
rule patents_process_compounds_chunk:
    input:
        chunk_file = os.path.join(COMPOUNDS_CHUNKED_DIR, "{chunk_name}.parquet")
    output:
        index = os.path.join(COMPOUNDS_DIR, "{chunk_name}.index"),
        metadata = os.path.join(COMPOUNDS_DIR, "{chunk_name}.json")
    params:
        script = os.path.join(MODULE_SCRIPTS, "process_compounds.py"),
        tracking_script = os.path.join(PROJECT_ROOT, "modules", "clinical_trials", "scripts", "chunk_tracking.py"),
        chunk_tracking_file = os.path.join(STATE_DIR, "processed_compounds_chunks.json"),
        fingerprint_bits = patents_config.get("fingerprint_bits", 2048),
        radius = patents_config.get("morgan_radius", 2),
        processing_batch_size = patents_config.get("processing_batch_size", 100000),
        LOG_cluster_log = os.path.join(config["logs_dir"], "cluster", f"patents_process_compounds_chunk_{{chunk_name}}.log")
    log:
        os.path.join(LOG_DIR, f"process_compounds_chunk_{{chunk_name}}_{RUN_TIMESTAMP}.log")
    conda:
        config["conda_env"]
    threads: 1
    resources:
        mem_mb=16384  # Only 16GB per chunk! (vs 256GB+ for all compounds)
    shell:
        """
        echo "==================== PROCESS COMPOUNDS CHUNK {wildcards.chunk_name} STARTED: $(date) ====================" > {log}

        python {params.script} \
            --input {input.chunk_file} \
            --output-index {output.index} \
            --output-metadata {output.metadata} \
            --fingerprint-bits {params.fingerprint_bits} \
            --radius {params.radius} \
            --processing-batch-size {params.processing_batch_size} \
            >> {log} 2>&1

        EXIT_CODE=$?

        if [ $EXIT_CODE -ne 0 ]; then
            echo "ERROR: Compound chunk processing failed with exit code $EXIT_CODE" >> {log}
            exit 1
        fi

        # Count fingerprints
        FP_COUNT=$(python -c "import json; data = json.load(open('{output.metadata}')); print(len(data))" 2>/dev/null || echo "0")
        echo "Fingerprints generated: $FP_COUNT" >> {log}

        # Extract chunk name for tracking (add .parquet extension)
        CHUNK_NAME="{wildcards.chunk_name}.parquet"

        # Mark chunk as processed in tracking file
        echo "Marking compounds chunk as processed in tracking file..." >> {log}
        python {params.tracking_script} \
            --tracking-file {params.chunk_tracking_file} \
            mark "$CHUNK_NAME" \
            --vectors "$FP_COUNT" \
            >> {log} 2>&1

        echo "Compounds chunk marked as processed in tracking" >> {log}

        echo "==================== PROCESS COMPOUNDS CHUNK {wildcards.chunk_name} COMPLETED: $(date) ====================" >> {log}
        """

