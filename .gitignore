# Data dirs (never tracked) — see IRREPLACEABLE.md for what these hold.
# Current layout (2026-06-13 reorg):
#   raw_data/  = ALL inputs, consolidated at root
#   work/      = pipeline working outputs (was "out"): data/ state/ logs/
#   out_prod/  = prod outputs container — the LIVE qdrant DB lives at out_prod/qdrant/
#   (qdrant/ + snapshots/ at root retired 2026-06-28; kept ignored as a safety net)
# Anchored to repo ROOT (leading /) so they only match the top-level data dirs and
# NEVER a code dir like modules/qdrant/.
/raw_data/
/work/
/out_prod/
/qdrant/
/snapshots/

# Legacy / other
data/
data.bkp/
logs/
logs.bkp/
out/
test_out/

# Generated config files (created on-the-fly from config.yaml + test_overrides.yaml)
config/test_config.yaml

